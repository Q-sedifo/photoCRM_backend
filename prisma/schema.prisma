
generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
}

model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String

  refreshToken String?

  createdAt    DateTime @default(now())
}

model Booking {
  id        Int      @id @default(autoincrement())

  name      String
  phone     String?
  telegram  String?

  date      DateTime
  comment   String?

  status    BookingStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryCategory {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  coverUrl  String?
  createdAt DateTime @default(now())

  photos    Photo[]
}

model Photo {
  id          Int      @id @default(autoincrement())
  imageUrl    String
  publicId    String
  alt         String?
  createdAt   DateTime @default(now())

  categoryId  Int
  category    GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}